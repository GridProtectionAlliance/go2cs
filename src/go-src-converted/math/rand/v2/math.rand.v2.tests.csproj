<Project>

  <!-- The test project shares its directory with the production project, and NuGet writes each
       project's restore artifacts (project.assets.json) to MSBuildProjectExtensionsPath — which
       defaults to obj\ for BOTH. Shared, the two projects overwrite each other's assets, and a
       production project pulled into the test build graph (bytes -> unicode/utf8) then READS the
       test project's assets and appears to reference ITSELF through the test closure — MSB4006
       "circular dependency involving ResolveProjectReferences". Distinct obj\tests\ / bin\tests\
       roots end the fight; the paths must be set BEFORE Sdk.props, hence the explicit SDK
       imports instead of the Sdk attribute. -->
  <PropertyGroup>
    <MSBuildProjectExtensionsPath>obj\tests\</MSBuildProjectExtensionsPath>
    <BaseIntermediateOutputPath>obj\tests\</BaseIntermediateOutputPath>
    <BaseOutputPath>bin\tests\</BaseOutputPath>
  </PropertyGroup>

  <Import Project="Sdk.props" Sdk="Microsoft.NET.Sdk" />

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <RootNamespace>go.math.rand</RootNamespace>
    <AssemblyName>math.rand.v2.tests</AssemblyName>
    <Product>go2cs</Product>
    <Description>$(AssemblyName) ($(TargetFramework) - $(Configuration))</Description>
    <AssemblyTitle>$(Description)</AssemblyTitle>
    <Company>Grid Protection Alliance</Company>
    <RepositoryUrl>https://github.com/ritchiecarroll/go2cs</RepositoryUrl>
    <Nullable>enable</Nullable>
    <NoWarn>CS0282;CS0660;CS0661;CS8618;CS8981;IDE0060;IDE1006;CA2255</NoWarn>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <IsPackable>false</IsPackable>
    <!-- The compile view must be EXACTLY the direct references the test converter computed: a
         transitive project reference that contributes a child `go.<pkg>` namespace (e.g.
         internal/testenv dragging io/fs, namespace go.io) collides with the converter's
         in-namespace `using io = io_package;` alias emission (CS0576) — the alias machinery is
         computed against the direct import closure only. -->
    <DisableTransitiveProjectReferences>true</DisableTransitiveProjectReferences>
  </PropertyGroup>

  <PropertyGroup Condition="'$(OutDir)'==''">
    <OutDir>bin\$(Configuration)\$(TargetFramework)\</OutDir>
  </PropertyGroup>

  <PropertyGroup Condition="'$(USERPROFILE)'==''">
    <USERPROFILE>$(HOME)</USERPROFILE>
  </PropertyGroup>

  <PropertyGroup Condition="'$(go2csPath)'==''">
    <go2csPath Condition="'$(Configuration)'!='Debug'">$(USERPROFILE)\go2cs\</go2csPath>
    <go2csPath Condition="'$(Configuration)'=='Debug' and '$(SolutionDir)'!=''">$(SolutionDir)</go2csPath>
    <go2csPath Condition="'$(go2csPath)'==''">$(MSBuildThisFileDirectory)../../../../</go2csPath>
  </PropertyGroup>

  <!-- Expose output of source generators as local files -->
  <PropertyGroup>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>

  <!-- Explicit compile items only (EnableDefaultCompileItems=false): the production sources are
       recompiled into the test assembly alongside the converted test sources; nothing else in the
       shared directory (Generated/**, *.cs.auto review siblings, the production package_info.cs)
       can leak in because it is never listed. -->
  <ItemGroup>
    <Compile Include="auto_test.cs" />
    <Compile Include="chacha8.cs" />
    <Compile Include="chacha8_test.cs" />
    <Compile Include="example_test.cs" />
    <Compile Include="exp.cs" />
    <Compile Include="export_test.cs" />
    <Compile Include="go2cs_test_host.cs" />
    <Compile Include="normal.cs" />
    <Compile Include="package_info_test.cs" />
    <Compile Include="package_test_info.cs" />
    <Compile Include="pcg.cs" />
    <Compile Include="pcg_test.cs" />
    <Compile Include="race_test.cs" />
    <Compile Include="rand.cs" />
    <Compile Include="rand_impl.cs" />
    <Compile Include="rand_test.cs" />
    <Compile Include="regress_test.cs" />
    <Compile Include="zipf.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="auto_test.go" CopyToOutputDirectory="PreserveNewest" />
    <None Include="chacha8.go" CopyToOutputDirectory="PreserveNewest" />
    <None Include="chacha8_test.go" CopyToOutputDirectory="PreserveNewest" />
    <None Include="example_test.go" CopyToOutputDirectory="PreserveNewest" />
    <None Include="exp.go" CopyToOutputDirectory="PreserveNewest" />
    <None Include="export_test.go" CopyToOutputDirectory="PreserveNewest" />
    <None Include="normal.go" CopyToOutputDirectory="PreserveNewest" />
    <None Include="pcg.go" CopyToOutputDirectory="PreserveNewest" />
    <None Include="pcg_test.go" CopyToOutputDirectory="PreserveNewest" />
    <None Include="race_test.go" CopyToOutputDirectory="PreserveNewest" />
    <None Include="rand.go" CopyToOutputDirectory="PreserveNewest" />
    <None Include="rand_test.go" CopyToOutputDirectory="PreserveNewest" />
    <None Include="regress_test.go" CopyToOutputDirectory="PreserveNewest" />
    <None Include="zipf.go" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(go2csPath)core\golib\golib.csproj" />
    <ProjectReference Include="$(go2csPath)core\testing\testing.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\bytes\bytes.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\crypto\sha256\crypto.sha256.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\encoding\hex\encoding.hex.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\errors\errors.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\flag\flag.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\fmt\fmt.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\go\format\go.format.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\hash\hash.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\internal\byteorder\internal.byteorder.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\internal\chacha8rand\internal.chacha8rand.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\internal\testenv\internal.testenv.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\io\fs\io.fs.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\io\io.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\math\bits\math.bits.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\math\math.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\os\os.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\reflect\reflect.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\runtime\runtime.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\strings\strings.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\sync\atomic\sync.atomic.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\sync\sync.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\testing\iotest\testing.iotest.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\text\tabwriter\text.tabwriter.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\time\time.csproj" />
    <ProjectReference Include="$(go2csPath)go-src-converted\unsafe\unsafe.csproj" />
    <ProjectReference Include="$(go2csPath)gen\go2cs-gen\go2cs-gen.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" PrivateAssets="All" />
  </ItemGroup>

  <!-- Define Go type aliases -->
  <ItemGroup>
    <Using Include="go.builtin" Static="True" />
    <Using Include="System" />
    <Using Include="System.Numerics" />
    <Using Include="System.Object" Alias="any" />
    <Using Include="System.Byte" Alias="uint8" />
    <Using Include="System.UInt16" Alias="uint16" />
    <Using Include="System.UInt32" Alias="uint32" />
    <Using Include="System.UInt64" Alias="uint64" />
    <Using Include="System.SByte" Alias="int8" />
    <Using Include="System.Int16" Alias="int16" />
    <Using Include="System.Int32" Alias="int32" />
    <Using Include="System.Int64" Alias="int64" />
    <Using Include="System.Single" Alias="float32" />
    <Using Include="System.Double" Alias="float64" />
    <Using Include="System.Numerics.Complex" Alias="complex128" />
    <Using Include="System.Int32" Alias="rune" />
    <Using Include="System.Numerics.BigInteger" Alias="GoUntyped" />
    <Using Include="System.ComponentModel.DescriptionAttribute" Alias="GoTagAttribute" />
    <Using Include="System.Runtime.CompilerServices.ModuleInitializerAttribute" Alias="GoInitAttribute" />
  </ItemGroup>

  <Import Project="Sdk.targets" Sdk="Microsoft.NET.Sdk" />

</Project>
