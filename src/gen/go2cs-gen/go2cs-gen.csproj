<Project Sdk="Microsoft.NET.Sdk">

  <!-- Shared NuGet version: go.gen carries the same stamp as the converted stdlib (src\version.props) -->
  <Import Project="..\..\version.props" />

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <RootNamespace>go2cs</RootNamespace>
    <Product>go2cs</Product>
    <Description>go2cs Roslyn source generator/analyzer emitting the C# glue (interface satisfaction, implicit conversions, receiver overloads, init ordering) for go2cs converted projects: $(AssemblyName) ($(TargetFramework) - $(Configuration))</Description>
    <Description></Description>
    <AssemblyTitle>$(Description)</AssemblyTitle>
    <Copyright>Copyright © 2026</Copyright>
    <Authors>$(Product) Authors</Authors>
    <Company>Grid Protection Alliance</Company>
    <RepositoryUrl>https://github.com/ritchiecarroll/go2cs</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <Title>go2cs source generator</Title>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>go.gen</PackageId>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageDescription>$(Description)</PackageDescription>
    <PackageProjectUrl>https://github.com/ritchiecarroll/go2cs</PackageProjectUrl>
    <PackageIcon>go2cs.png</PackageIcon>
    <PackageTags>go2cs;Golang;go;roslyn;analyzer;source-generator</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <IsRoslynComponent>true</IsRoslynComponent>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.10.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.3.4" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <Service Include="{508349b6-6b84-4df5-91f0-309beebad82d}" />
  </ItemGroup>

  <!-- Analyzer packaging: no lib/, no runtime dependencies, development-time only -->
  <PropertyGroup>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <DevelopmentDependency>true</DevelopmentDependency>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);_AddGeneratorToPackage</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <!-- Pack the built generator DLL into the analyzer path (runs after build, so the DLL exists) -->
  <Target Name="_AddGeneratorToPackage">
    <ItemGroup>
      <TfmSpecificPackageFile Include="$(OutputPath)$(AssemblyName).dll" PackagePath="analyzers/dotnet/cs" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <None Include="..\..\core\go2cs.png" Pack="true" PackagePath="" Visible="false" />
    <None Include="README.md" Pack="true" PackagePath="" />
  </ItemGroup>

  <Import Project="..\..\core\go2cs\go2cs.projitems" Label="Shared" />
</Project>
