namespace go;

using fmt = fmt_package;

partial class main_package {

internal static void Main() {
    var a = 0.25D;
    var b = 3D;
    var c = 0.3333333333333333D;
    fmt.Println(a, b, c);
    var d = 2D;
    var e = 100D;
    var f = 0.03D;
    fmt.Println(d, e, f);
    float32 g = 0.25F;
    float32 h = 2F;
    float32 i = 100F;
    fmt.Println(g, h, i);
    float32 j = 1.0000001F;
    fmt.Println(j);
    var z = 0.25D.i();
    var w = 16D.i();
    var v = 2D.i();
    fmt.Println(z, w, v);
    complex64 c64 = 0.25F.i();
    complex64 c64b = 16F.i();
    fmt.Println(c64, c64b);
    var k = 1.5e-3D;
    var l = 0.25D;
    float32 m = 0.1F;
    var n = 2D.i();
    fmt.Println(k, l, m, n);
}

} // end main_package
