<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Standalone runner for the go2cs performance comparison suite.

    Deliberately dependency-free: it orchestrates external processes (go2cs.exe, go build,
    dotnet build/publish, the benchmark programs) and reduces their timings into a markdown
    report. It references NO project (not even golib) and is NOT hosted in testhost.exe, for
    the same isolation reasons as the sibling BehavioralRunner.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>PerformanceRunner</AssemblyName>
    <RootNamespace>PerformanceRunner</RootNamespace>
    <IsPackable>false</IsPackable>
    <!-- Not part of any solution build; invoked directly via run-performance.ps1 / dotnet run. -->
  </PropertyGroup>

</Project>
